      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(vercel *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ]
  },
  "context": {
    "include": [
      "README.md",
      "app/**/*.tsx",
      "app/**/*.ts",
      "components/**/*.tsx",
      "components/**/*.ts",
      "package.json",
      ".env.example"
    ]
  }
}
