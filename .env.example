# Coming Soon Mode
# Set to 'true' to show coming soon page, 'false' to show full site
NEXT_PUBLIC_COMING_SOON=true

# Proton Mail SMTP (for contact form emails)
# Generate SMTP token in Proton Mail: Settings → All settings → IMAP/SMTP → Generate token
PROTON_SMTP_USER=team@hexprove.com
PROTON_SMTP_PASS=your-smtp-token-here
