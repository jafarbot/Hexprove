# Coming Soon Mode
# Set to 'true' to show coming soon page, 'false' to show full site
NEXT_PUBLIC_COMING_SOON=true

# Proton Mail SMTP (for contact form emails)
# Generate SMTP token in Proton Mail: Settings → All settings → IMAP/SMTP → Generate token
PROTON_SMTP_USER=team@hexprove.com
PROTON_SMTP_PASS=your-smtp-token-here

# Umami Analytics (Free, Privacy-Focused)
# Sign up at https://cloud.umami.is or self-host
# Get website ID from Settings → Websites → [Your Site] → Tracking Code
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id-here
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Google Analytics 4 (optional)
# Create property at https://analytics.google.com → Admin → Data Streams
# Note: NEXT_PUBLIC_* vars are baked in at BUILD time — redeploy after adding/changing
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Enable analytics in development
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
